APP_NAME=Golang
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=postgresql_project
DB_USERNAME=postgres
DB_PASSWORD=
# sslmode: disable (local), require, verify-full (prod)
DB_SSLMODE=disable
# Connection pool (optional)
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=25
DB_CONN_MAX_LIFETIME=5m

# Run AutoMigrate-style schema setup on boot? Use golang-migrate in production instead.
RUN_MIGRATIONS=true

CACHE_STORE=redis
# CACHE_PREFIX=

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

APP_PORT=8080

# Generate with: go run ./cmd/keygen
SESSION_SECRET=
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY_MINUTES=60
JWT_REFRESH_EXPIRY_DAYS=30

# Comma-separated. Leave empty to skip host validation.
ALLOWED_HOSTS=http://localhost:8080
ALLOWED_ORIGIN=http://localhost:8080

GIN_LOG_PATH=gin.log

# Admin seeder password (used only by cmd/seeder)
ADMIN_SEEDER_PASSWORD=Admin@Secure#2026!
